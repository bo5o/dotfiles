{
  "$schema": "https://lnav.org/schemas/config-v1.schema.json",
  "ui": {
    "theme-defs": {
      "gruvbox-material": {
        "vars": {
          "bg_dim": "#1b1b1b",
          "bg0": "#282828",
          "bg1": "#32302f",
          "bg2": "#32302f",
          "bg3": "#45403d",
          "bg4": "#45403d",
          "bg5": "#5a524c",
          "bg_statusline1": "#32302f",
          "bg_statusline2": "#3a3735",
          "bg_statusline3": "#504945",
          "bg_current_word": "#3c3836",
          "bg_visual_red": "#4c3432",
          "bg_visual_green": "#3b4439",
          "bg_visual_blue": "#374141",
          "bg_visual_yellow": "#4f422e",
          "bg_visual_purple": "#443840",
          "bg_diff_red": "#402120",
          "bg_diff_green": "#34381b",
          "bg_diff_blue": "#0e363e",
          "fg0": "#d4be98",
          "fg1": "#ddc7a1",
          "grey0": "#7c6f64",
          "grey1": "#928374",
          "grey2": "#a89984",
          "red": "#ea6962",
          "orange": "#e78a4e",
          "yellow": "#d8a657",
          "green": "#a9b665",
          "aqua": "#89b482",
          "blue": "#7daea3",
          "purple": "#d3869b",
          "semantic_highlight_color": "semantic()"
        },
        "styles": {
          "text": { "color": "$fg0", "background-color": "$bg0" },
          "alt-text": { "background-color": "$bg1" },
          "ok": { "color": "$green", "bold": true },
          "error": { "color": "$red", "bold": true },
          "warning": { "color": "$yellow", "bold": true },
          "info": { "color": "$aqua", "bold": true },
          "hidden": { "color": "$grey0" },
          "adjusted-time": { "color": "$purple" },
          "skewed-time": { "color": "$yellow" },
          "offset-time": { "color": "$aqua" },
          "invalid-msg": { "color": "$red" },
          "focused": { "color": "$bg0", "background-color": "$fg0" },
          "disabled-focused": { "color": "$bg0", "background-color": "$bg3" },
          "popup": { "color": "$fg0", "background-color": "$bg1" },
          "popup-border": { "color": "$bg5", "background-color": "$bg1" },
          "scrollbar": { "color": "$fg0", "background-color": "$bg3" },
          "h1": { "color": "$yellow", "bold": true, "underline": true },
          "h2": { "color": "$orange", "bold": true, "underline": true },
          "h3": { "color": "$purple", "underline": true },
          "h4": { "underline": true },
          "h5": { "underline": true },
          "h6": { "underline": true },
          "hr": { "color": "$bg5" },
          "hyperlink": { "color": "$blue", "underline": true },
          "list-glyph": { "color": "$yellow" },
          "breadcrumb": { "color": "$grey1", "bold": true },
          "table-border": { "color": "$bg3" },
          "table-header": { "bold": true },
          "quote-border": { "color": "$bg5", "background-color": "$bg1" },
          "quoted-text": { "background-color": "$bg1" },
          "snippet-border": { "color": "$aqua" },
          "indent-guide": { "color": "$bg3" },
          "selected-text": { "background-color": "$bg_visual_blue" },
          "fuzzy-match": { "color": "$yellow", "underline": true },
          "cursor-line": { "color": "$fg0", "background-color": "$bg_current_word", "bold": true },
          "highlight": { "color": "$yellow", "bold": true },
          "search": { "color": "$bg0", "background-color": "$yellow" },
          "inline-code": { "color": "$orange", "background-color": "$bg1" }
        },
        "status-styles": {
          "text":           { "color": "$fg0",   "background-color": "$bg_statusline2" },
          "warn":           { "color": "$yellow","background-color": "$bg_statusline2" },
          "alert":          { "color": "$red",   "background-color": "$bg_statusline2" },
          "active":         { "color": "$green", "background-color": "$bg_statusline2", "bold": true },
          "inactive":       { "color": "$grey1", "background-color": "$bg_statusline1" },
          "inactive-warn":  { "color": "$yellow","background-color": "$bg_statusline1" },
          "inactive-alert": { "color": "$red",   "background-color": "$bg_statusline1" },
          "title":          { "color": "$bg0",   "background-color": "$aqua", "bold": true },
          "alert-title":    { "color": "$bg0",   "background-color": "$red",  "bold": true },
          "disabled-title": { "color": "$grey1", "background-color": "$bg_statusline2" },
          "title-hotkey":   { "color": "$bg0",   "background-color": "$aqua", "underline": true },
          "subtitle":       { "color": "$bg0",   "background-color": "$blue" },
          "info":           { "color": "$fg0",   "background-color": "$bg_statusline3" },
          "hotkey":         { "color": "$yellow","background-color": "$bg_statusline2", "underline": true },
          "suggestion":     { "color": "$grey0" }
        },
        "syntax-styles": {
          "quoted-code": { "color": "$fg0", "background-color": "$bg1" },
          "code-border": { "color": "$bg5", "background-color": "$bg1" },
          "keyword": { "color": "$red" },
          "string": { "color": "$green" },
          "comment": { "color": "$grey1", "italic": true },
          "doc-directive": { "color": "$aqua" },
          "variable": { "color": "$blue" },
          "symbol": { "color": "$purple" },
          "re-special": { "color": "$aqua" },
          "re-repeat": { "color": "$yellow" },
          "diff-delete": { "color": "$red" },
          "diff-add": { "color": "$green" },
          "diff-section": { "color": "$yellow" },
          "file": { "color": "$blue" },
          "null": { "color": "$grey1", "bold": true },
          "ascii-control": { "color": "$red" },
          "non-ascii": { "color": "$yellow" },
          "number": { "color": "$purple" },
          "type": { "color": "$yellow" },
          "function": { "color": "$green" },
          "separators-references-accessors": { "color": "$grey1" }
        }
      }
    }
  }
}
